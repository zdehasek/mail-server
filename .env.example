# mailserver init copies this file to ~/.mail-server/config.env.
# mailserver loads that config automatically and installer scripts source it as Bash.

# Hostnames and domain
MAIL_HOSTNAME=mail.example.com
PRIMARY_DOMAIN=example.com
SECONDARY_DOMAINS=
ADMIN_EMAIL=admin@example.com
WEBMAIL_HOSTNAME=mail.example.com
DAV_HOSTNAME=dav.example.com

# Public IPs and system identity
SERVER_PUBLIC_IPV4=203.0.113.10
SERVER_PUBLIC_IPV6=
TIMEZONE=UTC

# Virtual mail storage and PostgreSQL database
VMAIL_UID=5000
VMAIL_GID=5000
VMAIL_ROOT=/var/vmail
MAIL_DB_NAME=mailserver
MAIL_DB_USER=mailserver
MAIL_DB_HOST=127.0.0.1
MAIL_DB_PASSWORD_FILE=/etc/mailserver/secrets/postgresql-mailserver-password
# Optional legacy SQLite path used only for one-time migration during upgrades.
MAIL_DB_PATH=/etc/mailserver/mail.sqlite

# Install features
LETSENCRYPT_STAGING=false
ENABLE_UFW=true
UFW_RESET_RULES=true
ENABLE_FAIL2BAN=true
ENABLE_SSH_HARDENING=true
ENABLE_RSPAMD=true
ENABLE_CLAMAV=false

# SSH hardening
SSH_PORT=22
SSH_ALLOW_USERS=

# Backups
BACKUP_DIR=/var/backups/mailserver-data
BACKUP_RETENTION_DAYS=14
BACKUP_CRON_SCHEDULE="17 3 * * *"

# Required mail aliases and DKIM
POSTMASTER_ADDRESS=postmaster@example.com
ABUSE_ADDRESS=abuse@example.com
DKIM_SELECTOR=default

# Optional primary mailbox created during setup.
# Leave PRIMARY_MAILBOX_PASSWORD empty to generate and store it in PRIMARY_MAILBOX_PASSWORD_FILE.
PRIMARY_MAILBOX=admin@example.com
PRIMARY_MAILBOX_FULL_NAME="Mail Admin"
PRIMARY_MAILBOX_PASSWORD=
PRIMARY_MAILBOX_PASSWORD_FILE=/etc/mailserver/secrets/primary-mailbox-password
PRIMARY_ALIAS_ADDRESSES="postmaster@example.com abuse@example.com dmarc@example.com admin@example.com"
